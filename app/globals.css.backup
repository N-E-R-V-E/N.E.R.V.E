@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;700&family=Bebas+Neue&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

/* ── THEME VARIABLES ── */
:root {
  --bg: #f0f0ee;
  --bg2: #e8e8e5;
  --bg3: #ffffff;
  --surface: rgba(255, 255, 255, 0.72);
  --border: rgba(0, 0, 0, 0.1);
  --border2: rgba(0, 0, 0, 0.06);
  --text: #0c0c0a;
  --text2: #4a4a46;
  --text3: #8a8a85;
  --accent: #E8891A;
  --accent2: #c96a00;
  --green: #16a34a;
  --shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
  --shadow2: 0 12px 48px rgba(0, 0, 0, 0.14);
  --nav-bg: rgba(240, 240, 238, 0.88);
  --card-bg: #e8e8e5;
  --card-bg2: #ffffff;
  --tele-bg: #f5f5f2;
  --tag-bg: rgba(232, 137, 26, 0.1);
  --lock-bg: rgba(0, 0, 0, 0.06);
}

@media (prefers-color-scheme: dark) {
  :root {
    --bg: #0a0a0c;
    --bg2: #111114;
    --bg3: #161618;
    --surface: rgba(22, 22, 26, 0.88);
    --border: rgba(255, 255, 255, 0.09);
    --border2: rgba(255, 255, 255, 0.05);
    --text: #f0f0ec;
    --text2: #a0a09a;
    --text3: #606060;
    --accent: #F59B2E;
    --accent2: #e8891a;
    --green: #22c55e;
    --shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
    --shadow2: 0 12px 48px rgba(0, 0, 0, 0.7);
    --nav-bg: rgba(10, 10, 12, 0.92);
    --card-bg: #161618;
    --card-bg2: #1c1c20;
    --tele-bg: #111114;
    --tag-bg: rgba(245, 155, 46, 0.12);
    --lock-bg: rgba(255, 255, 255, 0.04);
  }
}

[data-theme='light'] {
  --bg: #f0f0ee;
  --bg2: #e8e8e5;
  --bg3: #ffffff;
  --surface: rgba(255, 255, 255, 0.72);
  --border: rgba(0, 0, 0, 0.1);
  --border2: rgba(0, 0, 0, 0.06);
  --text: #0c0c0a;
  --text2: #4a4a46;
  --text3: #8a8a85;
  --accent: #E8891A;
  --accent2: #c96a00;
  --green: #16a34a;
  --shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
  --shadow2: 0 12px 48px rgba(0, 0, 0, 0.14);
  --nav-bg: rgba(240, 240, 238, 0.88);
  --card-bg: #e8e8e5;
  --card-bg2: #ffffff;
  --tele-bg: #f5f5f2;
  --tag-bg: rgba(232, 137, 26, 0.1);
  --lock-bg: rgba(0, 0, 0, 0.06);
}

[data-theme='dark'] {
  --bg: #0a0a0c;
  --bg2: #111114;
  --bg3: #161618;
  --surface: rgba(22, 22, 26, 0.88);
  --border: rgba(255, 255, 255, 0.09);
  --border2: rgba(255, 255, 255, 0.05);
  --text: #f0f0ec;
  --text2: #a0a09a;
  --text3: #606060;
  --accent: #F59B2E;
  --accent2: #e8891a;
  --green: #22c55e;
  --shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
  --shadow2: 0 12px 48px rgba(0, 0, 0, 0.7);
  --nav-bg: rgba(10, 10, 12, 0.92);
  --card-bg: #161618;
  --card-bg2: #1c1c20;
  --tele-bg: #111114;
  --tag-bg: rgba(245, 155, 46, 0.12);
  --lock-bg: rgba(255, 255, 255, 0.04);
}

*,
*::before,
*::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  -webkit-font-smoothing: antialiased;
}

body {
  font-family: 'Space Grotesk', sans-serif;
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  transition: background 0.2s, color 0.2s;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(24px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes glowPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(232, 137, 26, 0); }
  50% { box-shadow: 0 0 24px 4px rgba(232, 137, 26, 0.18); }
}

@keyframes scanLine {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(100vh); }
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-30px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes countUp {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.cursor-dot {
  width: 7px;
  height: 7px;
  background: var(--accent);
  border-radius: 50%;
  position: fixed;
  top: 0;
  left: 0;
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: width 0.18s, height 0.18s;
}

.cursor-ring {
  width: 28px;
  height: 28px;
  border: 1.5px solid var(--accent);
  border-radius: 50%;
  position: fixed;
  top: 0;
  left: 0;
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%, -50%);
  opacity: 0.6;
  transition: width 0.2s, height 0.2s;
}

@media (hover: none) {
  .cursor-dot, .cursor-ring {
    display: none;
  }
}

.scan-line {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 2px;
  background: linear-gradient(to right, transparent, rgba(245, 155, 46, 0.06), transparent);
  pointer-events: none;
  z-index: 998;
  animation: scanLine 7s linear infinite;
  opacity: 0;
  transition: opacity 0.4s;
}

[data-theme='dark'] .scan-line {
  opacity: 1;
}

.nav {
  height: 64px;
  background: var(--nav-bg);
  backdrop-filter: blur(20px) saturate(1.4);
  -webkit-backdrop-filter: blur(20px) saturate(1.4);
  display: flex;
  align-items: center;
  padding: 0 48px;
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 500;
  animation: fadeIn 0.6s ease;
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
  cursor: pointer;
}

.nav-logo-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  letter-spacing: 0.12em;
  color: var(--text);
}

.nav-logo-sub {
  font-family: 'JetBrains Mono', monospace;
  font-size: 7px;
  letter-spacing: 0.25em;
  color: var(--text3);
  margin-top: 1px;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 32px;
  list-style: none;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.nav-links li {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.14em;
  color: var(--text2);
  cursor: pointer;
  white-space: nowrap;
  position: relative;
  transition: color 0.2s;
}

.nav-links li::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--accent);
  transition: width 0.25s;
}

.nav-links li:hover {
  color: var(--text);
}

.nav-links li:hover::after {
  width: 100%;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-left: auto;
}

.theme-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: transparent;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text2);
  transition: border-color 0.2s, color 0.2s;
}

.theme-btn:hover {
  border-color: var(--text);
  color: var(--text);
}

.btn {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.12em;
  cursor: pointer;
  border-radius: 3px;
  height: 36px;
  padding: 0 18px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: all 0.18s;
  text-decoration: none;
}

.btn-outline {
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text);
}

.btn-outline:hover {
  border-color: var(--text);
  background: var(--text);
  color: var(--bg);
}

.btn-solid {
  border: none;
  background: var(--text);
  color: var(--bg);
}

.btn-solid:hover {
  opacity: 0.82;
}

.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  margin-left: auto;
}

.hamburger span {
  width: 22px;
  height: 2px;
  background: var(--text);
  transition: all 0.3s;
  border-radius: 1px;
}

.hamburger:hover span {
  opacity: 0.7;
}

.mobile-menu {
  position: absolute;
  top: 64px;
  left: 0;
  right: 0;
  background: var(--nav-bg);
  border-bottom: 1px solid var(--border);
  padding: 12px 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  z-index: 400;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  animation: slideDown 0.2s ease;
}

.mobile-menu ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.mobile-menu li {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.14em;
  color: var(--text2);
  cursor: pointer;
  padding: 8px 0;
  border-bottom: 1px solid var(--border2);
}

.mobile-menu li:last-child {
  border-bottom: none;
  margin-bottom: 8px;
}

.mobile-menu li:active {
  color: var(--accent);
}

@media (max-width: 900px) {
  .nav-links {
    display: none;
  }
  .nav {
    padding: 0 20px;
  }
  .hamburger {
    display: flex;
  }
  .btn-solid {
    display: none;
  }
}

.content {
  padding: 0 48px;
  max-width: 1480px;
  margin: 0 auto;
}

@media (max-width: 700px) {
  .content {
    padding: 0 20px;
  }
}

.hero {
  position: relative;
  padding-top: 52px;
  min-height: 560px;
  display: flex;
  align-items: flex-start;
}

.hero-left {
  position: relative;
  z-index: 2;
  width: 520px;
  flex-shrink: 0;
}

.hero-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.18em;
  color: var(--accent);
  margin-bottom: 14px;
  animation: fadeUp 0.7s 0.1s both;
}

.nerve-heading {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 118px;
  line-height: 0.88;
  color: var(--text);
  letter-spacing: 0.04em;
  animation: fadeUp 0.7s 0.2s both;
  margin: 0;
}

.hero-subtitle {
  font-size: 18px;
  font-weight: 600;
  line-height: 1.35;
  color: var(--text);
  margin: 16px 0 10px;
  animation: fadeUp 0.7s 0.32s both;
}

.hero-body {
  font-size: 13px;
  color: var(--text3);
  line-height: 1.75;
  margin-bottom: 28px;
  max-width: 360px;
  animation: fadeUp 0.7s 0.42s both;
}

.hero-btns {
  display: flex;
  gap: 12px;
  margin-bottom: 32px;
  animation: fadeUp 0.7s 0.52s both;
  flex-wrap: wrap;
}

.btn-hero {
  height: 46px;
  padding: 0 24px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.13em;
  border-radius: 3px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
  border: none;
}

.btn-hero-solid {
  background: var(--text);
  color: var(--bg);
}

.btn-hero-solid:hover {
  opacity: 0.82;
  transform: translateY(-1px);
}

.btn-hero-outline {
  background: transparent;
  color: var(--text);
  border: 1px solid var(--border);
}

.btn-hero-outline:hover {
  border-color: var(--text);
  background: var(--text);
  color: var(--bg);
  transform: translateY(-1px);
}

.hero-image-wrap {
  position: absolute;
  top: -64px;
  right: -48px;
  width: calc(100% - 460px);
  height: 580px;
  border-radius: 2px;
  overflow: hidden;
  z-index: 0;
  animation: fadeIn 1s 0.3s both;
}

.hero-image-wrap::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, var(--bg) 0%, transparent 30%);
  z-index: 2;
  pointer-events: none;
}

.hero-image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}

.hero-image-wrap:hover img {
  transform: scale(1.03);
}

.hero-status {
  position: absolute;
  bottom: 20px;
  right: 20px;
  z-index: 10;
  display: flex;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  backdrop-filter: blur(14px);
  animation: glowPulse 4s ease-in-out infinite;
}

.hero-status-cell {
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.hero-status-cell + .hero-status-cell {
  border-left: 1px solid var(--border);
}

.status-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 8px;
  letter-spacing: 0.2em;
  color: var(--text3);
  text-transform: uppercase;
  margin: 0;
}

.status-value {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  font-weight: 700;
  color: var(--text);
  display: flex;
  align-items: center;
  gap: 7px;
  margin: 0;
}

.green-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--green);
  animation: pulse 2s ease-in-out infinite;
  flex-shrink: 0;
}

@media (max-width: 900px) {
  .hero {
    flex-direction: column;
    min-height: auto;
  }
  .hero-left {
    width: 100%;
  }
  .nerve-heading {
    font-size: 72px;
  }
  .hero-image-wrap {
    position: relative;
    top: 0;
    right: 0;
    width: 100%;
    height: 260px;
    margin-top: 24px;
  }
  .hero-image-wrap::after {
    background: linear-gradient(to bottom, var(--bg) 0%, transparent 20%);
  }
  .hero-status {
    display: none;
  }
}

.tele-bar {
  display: flex;
  align-items: stretch;
  margin-top: 24px;
  border-radius: 10px;
  overflow: hidden;
  background: var(--tele-bg);
  border: 1px solid var(--border);
  animation: fadeUp 0.7s 0.7s both;
}

.tele-cell {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 18px 20px;
  position: relative;
  transition: background 0.2s;
  cursor: default;
  border-right: 1px solid var(--border2);
}

.tele-cell:last-of-type {
  border-right: none;
}

.tele-cell:hover {
  background: rgba(0, 0, 0, 0.03);
}

@media (prefers-color-scheme: dark) {
  .tele-cell:hover {
    background: rgba(255, 255, 255, 0.02);
  }
}

.tele-icon {
  color: var(--text3);
  flex-shrink: 0;
  transition: color 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tele-cell:hover .tele-icon {
  color: var(--accent);
}

.tele-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 8px;
  letter-spacing: 0.16em;
  color: var(--text3);
  margin: 0;
  text-transform: uppercase;
  line-height: 1;
}

.tele-value {
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.02em;
  line-height: 1;
  margin: 0;
  animation: countUp 0.35s ease;
}

.tele-cta {
  background: var(--text);
  color: var(--bg);
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 18px 22px;
  min-width: 180px;
  cursor: pointer;
  flex-shrink: 0;
  border-left: 1px solid var(--border);
  transition: opacity 0.2s;
  border: none;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.tele-cta:hover {
  opacity: 0.82;
}

.tele-cta span {
  line-height: 1.6;
  color: var(--bg);
  display: block;
  text-align: left;
}

.tele-cta svg {
  stroke: var(--bg);
  flex-shrink: 0;
  stroke-width: 2;
}

@media (max-width: 900px) {
  .tele-bar {
    flex-wrap: wrap;
  }
  .tele-cell {
    min-width: 33.3%;
    flex: 0 0 calc(33.3% - 1px);
  }
  .tele-cta {
    width: 100%;
    min-width: unset;
    flex: 0 0 100%;
  }
}

.research-section {
  margin-top: 80px;
  padding-top: 60px;
  border-top: 1px solid var(--border);
}

.research-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: 10px;
  overflow: hidden;
}

@media (max-width: 900px) {
  .research-grid {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 600px) {
  .research-grid {
    grid-template-columns: 1fr;
  }
}

.research-card {
  background: var(--bg);
  padding: 28px 24px 36px;
  cursor: pointer;
  transition: background 0.22s;
  position: relative;
  overflow: hidden;
}

.research-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 2px;
  height: 0;
  background: var(--accent);
  transition: height 0.3s ease;
}

.research-card:hover::before {
  height: 100%;
}

.research-card:hover {
  background: var(--bg2);
}

.rc-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 0.1em;
  margin-bottom: 14px;
}

.rc-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8px;
  line-height: 1.3;
}

.rc-body {
  font-size: 12.5px;
  color: var(--text3);
  line-height: 1.65;
}

.rc-arrow {
  position: absolute;
  bottom: 20px;
  right: 20px;
  color: var(--text3);
  opacity: 0;
  transform: translate(-4px, 4px);
  transition: all 0.25s;
}

.research-card:hover .rc-arrow {
  opacity: 1;
  transform: translate(0, 0);
  color: var(--accent);
}

.research-card.locked {
  cursor: default;
}

.research-card.locked::before {
  display: none;
}

.research-card.locked .rc-title,
.research-card.locked .rc-body {
  filter: blur(3px) opacity(0.5);
  user-select: none;
}

.lock-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.14em;
  color: var(--text3);
  background: var(--lock-bg);
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 3px 8px;
  margin-bottom: 12px;
}

.lock-badge svg {
  flex-shrink: 0;
}

.sec-eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--accent);
  margin-bottom: 14px;
}

.sec-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 68px;
  letter-spacing: 0.06em;
  color: var(--text);
  line-height: 0.9;
  margin-bottom: 12px;
}

.sec-desc {
  font-size: 14px;
  color: var(--text2);
  max-width: 520px;
  line-height: 1.75;
  margin-bottom: 40px;
}

.toast {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: var(--text);
  color: var(--bg);
  border-radius: 6px;
  padding: 10px 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.08em;
  z-index: 3000;
  opacity: 0;
  transition: opacity 0.3s, transform 0.3s;
  pointer-events: none;
}

.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* ── FOUNDER CARDS SECTION ── */
.founder-section {
  margin-top: 80px;
  padding-top: 60px;
  border-top: 1px solid var(--border);
}

.founder-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 24px;
  margin-top: 40px;
}

.founder-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 28px;
  transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.founder-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(232, 137, 26, 0.1), transparent);
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}

.founder-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow2);
  border-color: var(--accent);
}

.founder-card:hover::before {
  opacity: 1;
}

.founder-avatar {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  border: 2px solid var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 24px;
  color: var(--accent);
  background: var(--tag-bg);
  margin-bottom: 16px;
  flex-shrink: 0;
}

.founder-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 24px;
  letter-spacing: 0.06em;
  color: var(--text);
  margin-bottom: 4px;
}

.founder-role {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.16em;
  color: var(--text3);
  margin-bottom: 12px;
  text-transform: uppercase;
}

.founder-bio {
  font-size: 13px;
  color: var(--text2);
  line-height: 1.65;
  margin-bottom: 16px;
}

.founder-socials {
  display: flex;
  gap: 8px;
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid var(--border2);
}

.social-link {
  width: 32px;
  height: 32px;
  border: 1px solid var(--border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text3);
  cursor: pointer;
  transition: all 0.2s;
  flex-shrink: 0;
}

.social-link:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: var(--tag-bg);
  transform: translateY(-2px);
}

/* ── GALLERY SECTION ── */
.gallery-section {
  margin-top: 80px;
  padding-top: 60px;
  border-top: 1px solid var(--border);
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 20px;
  margin-top: 40px;
}

.gallery-item {
  position: relative;
  border-radius: 10px;
  overflow: hidden;
  aspect-ratio: 1;
  cursor: pointer;
  background: var(--bg2);
  border: 1px solid var(--border);
}

.gallery-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
  display: block;
}

.gallery-item:hover img {
  transform: scale(1.05);
}

.gallery-item::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(232, 137, 26, 0.2), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.gallery-item:hover::after {
  opacity: 1;
}

/* ── WORKSHOPS SECTION ── */
.workshops-section {
  margin-top: 80px;
  padding-top: 60px;
  border-top: 1px solid var(--border);
}

.workshop-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: 10px;
  overflow: hidden;
  margin-top: 40px;
}

.workshop-item {
  background: var(--bg3);
  padding: 24px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
  transition: all 0.22s;
  gap: 16px;
}

.workshop-item:hover {
  background: var(--surface);
  backdrop-filter: blur(10px);
  transform: translateX(6px);
}

.workshop-info {
  flex: 1;
}

.workshop-name {
  font-size: 14px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 4px;
}

.workshop-meta {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  color: var(--text3);
  letter-spacing: 0.08em;
}

.workshop-badge {
  font-family: 'JetBrains Mono', monospace;
  font-size: 8.5px;
  letter-spacing: 0.1em;
  padding: 4px 10px;
  border-radius: 2px;
  border: 1px solid var(--border);
  color: var(--text3);
  flex-shrink: 0;
  transition: all 0.2s;
}

.workshop-badge.open {
  border-color: var(--green);
  color: var(--green);
  background: rgba(22, 163, 74, 0.08);
}

/* ── INSIGHTS SECTION ── */
.insights-section {
  margin-top: 80px;
  padding-top: 60px;
  border-top: 1px solid var(--border);
}

.insights-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 24px;
  margin-top: 40px;
}

.insight-card {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 10px;
  overflow: hidden;
  transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
}

.insight-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow2);
  border-color: var(--accent);
}

.insight-image {
  width: 100%;
  height: 160px;
  object-fit: cover;
  display: block;
  background: var(--bg2);
}

.insight-body {
  padding: 20px;
}

.insight-source {
  font-family: 'JetBrains Mono', monospace;
  font-size: 8px;
  color: var(--accent);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 8px;
}

.insight-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.4;
  margin-bottom: 10px;
}

.insight-excerpt {
  font-size: 12px;
  color: var(--text3);
  line-height: 1.6;
  margin-bottom: 14px;
}

.insight-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 14px;
  border-top: 1px solid var(--border2);
  font-size: 11px;
  color: var(--text3);
}

.insight-link {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  color: var(--accent);
  text-decoration: none;
  cursor: pointer;
  transition: opacity 0.2s;
}

.insight-link:hover {
  opacity: 0.7;
}

/* ── DOWNLOADS PAGE ── */
.downloads-section {
  margin-top: 80px;
  padding-top: 60px;
  border-top: 1px solid var(--border);
  margin-bottom: 60px;
}

.downloads-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  margin-top: 40px;
}

.download-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 28px;
  transition: all 0.25s;
  backdrop-filter: blur(10px);
}

.download-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow2);
  border-color: var(--accent);
}

.download-icon {
  width: 50px;
  height: 50px;
  background: var(--tag-bg);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent);
  font-size: 24px;
  margin-bottom: 16px;
}

.download-name {
  font-size: 16px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8px;
}

.download-desc {
  font-size: 13px;
  color: var(--text3);
  line-height: 1.6;
  margin-bottom: 16px;
}

.download-meta {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  color: var(--text3);
  margin-bottom: 14px;
}

.download-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.1em;
  color: var(--accent);
  border: 1px solid var(--accent);
  background: transparent;
  border-radius: 3px;
  padding: 8px 16px;
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
}

.download-btn:hover {
  background: var(--accent);
  color: var(--bg);
}

@media (max-width: 900px) {
  .founder-cards,
  .gallery-grid,
  .insights-grid,
  .downloads-grid {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
}
